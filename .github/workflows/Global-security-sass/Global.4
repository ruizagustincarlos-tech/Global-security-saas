import os
import re
from core.rules import RULES

def scan_file(filepath):
    findings = []

    with open(filepath, "r", encoding="utf-8", errors="ignore") as f:
        for i, line in enumerate(f, 1):
            for rule in RULES:
                if re.search(rule["pattern"], line, re.IGNORECASE):
                    findings.append({
                        "file": filepath,
                        "line": i,
                        "rule": rule["name"],
                        "severity": rule["severity"],
                        "code": line.strip(),
                        "desc": rule["desc"]
                    })

    return findings


def scan_project(path):
    results = []

    for root, _, files in os.walk(path):
        for file in files:
            if file.endswith((".py", ".js", ".php")):
                results.extend(scan_file(os.path.join(root, file)))

    return results
import json
from datetime import datetime

def print_console(findings):
    if not findings:
        print("✔ Sin problemas detectados")
        return

    for f in findings:
        print(f"[{f['severity']}] {f['rule']}")
        print(f"{f['file']}:{f['line']}")
        print(f"→ {f['code']}")
        print("-" * 40)

def export_json(findings):
    filename = f"reports/report_{datetime.now().timestamp()}.json"
    with open(filename, "w") as f:
        json.dump(findings, f, indent=4)
    print(f"Reporte guardado en {filename}")
import argparse
from core.scanner import scan_project
from core.reporter import print_console, export_json

def main():
    parser = argparse.ArgumentParser(description="GLOBAL Security Scanner")
    parser.add_argument("path", help="Ruta del proyecto")
    parser.add_argument("--json", action="store_true", help="Exportar JSON")

    args = parser.parse_args()

    findings = scan_project(args.path)
    print_console(findings)

    if args.json:
        export_json(findings)

    # Falla CI si hay críticos
    for f in findings:
        if f["severity"] == "CRITICAL":
            exit(1)

if __name__ == "__main__":
    main()
